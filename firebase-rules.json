{
  "rules": {
    "users": {
      "$uid": {
        ".read": true,
        ".write": "auth != null && auth.uid === $uid",
        "email": { ".validate": "newData.isString()" },
        "name": { ".validate": "newData.isString() && newData.val().length <= 100" },
        "pfp": { ".validate": "newData.isString() && newData.val().length <= 100" },
        "status": { ".validate": "newData.isString()" },
        "lastSeen": { ".validate": "newData.isNumber()" },
        "createdAt": { ".validate": "newData.isString() || newData.isNumber()" }
      }
    },

    "cards": {
      "$cardId": {
        "offers": {
          ".read": true,
          "$offerId": {
            ".write": "auth != null && ((newData.exists() && newData.child('uid').val() == auth.uid) || (!newData.exists() && (data.child('uid').val() == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin')))",
            ".validate": "newData.hasChildren(['uid','price','desc','createdAt'])",
            "uid": { ".validate": "newData.val() === auth.uid" },
            "displayName": { ".validate": "newData.isString() && newData.val().length <= 100" },
            "photoURL": { ".validate": "newData.isString() || newData.val() === null" },
            "price": { ".validate": "newData.isNumber() && newData.val() > 0" },
            "condition": { ".validate": "newData.isString() && newData.val().length <= 100" },
            "desc": { ".validate": "newData.isString() && newData.val().length <= 1000" },
            "createdAt": { ".validate": "newData.isNumber()" },
            "soldCount": { ".validate": "newData.isNumber()" },
            "replies": {
              "$replyId": {
                ".write": "auth != null && (data.val() === null || data.child('uid').val() === auth.uid)",
                ".validate": "newData.hasChildren(['uid','text','createdAt'])",
                "uid": { ".validate": "newData.val() === auth.uid" },
                "displayName": { ".validate": "newData.isString() && newData.val().length <= 100" },
                "photoURL": { ".validate": "newData.isString() || newData.val() === null" },
                "text": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 1000" },
                "createdAt": { ".validate": "newData.isNumber()" }
              }
            }
          }
        },
        "comments": {
          ".read": true,
          "$commentId": {
            ".write": "auth != null && (data.val() === null || data.child('uid').val() === auth.uid)",
            ".validate": "newData.hasChildren(['uid','text','createdAt'])",
            "uid": { ".validate": "newData.val() === auth.uid" },
            "displayName": { ".validate": "newData.isString() && newData.val().length <= 100" },
            "photoURL": { ".validate": "newData.isString() || newData.val() === null" },
            "text": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 1000" },
            "createdAt": { ".validate": "newData.isNumber()" }
          }
        }
      }
    },

    "user_rooms": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$roomId": {
          ".validate": "newData.hasChildren(['name','lastTs','partnerId'])",
          "name": { ".validate": "newData.isString() && newData.val().length <= 100" },
          "avatar": { ".validate": "newData.isString() || newData.val() === null" },
          "lastMsg": { ".validate": "newData.isString() && newData.val().length <= 200" },
          "lastTs": { ".validate": "newData.isNumber()" },
          "partnerId": { ".validate": "newData.isString()" }
        }
      }
    },

    "chats": {
      "$roomId": {
        ".read": "auth != null && $roomId.contains(auth.uid)",
        ".write": "auth != null && $roomId.contains(auth.uid)",
        "messages": {
          ".indexOn": ["createdAt"],
          "$msgId": {
            ".write": "auth != null && $roomId.contains(auth.uid) && (data.val() === null || data.child('uid').val() === auth.uid)",
            ".validate": "newData.hasChildren(['uid','createdAt']) || !newData.exists()",
            "uid": { ".validate": "newData.val() === auth.uid" },
            "displayName": { ".validate": "newData.isString() && newData.val().length <= 100" },
            "photoURL": { ".validate": "newData.isString() || newData.val() === null" },
            "text": { ".validate": "newData.isString() && newData.val().length <= 2000" },
            "imageUrl": { ".validate": "newData.isString() || newData.val() === null" },
            "fileName": { ".validate": "newData.isString() || newData.val() === null" },
            "createdAt": { ".validate": "newData.isNumber()" },
            "deletedFor": {
              "$uid": {
                ".write": "auth != null && auth.uid === $uid && $roomId.contains(auth.uid)",
                ".validate": "newData.isBoolean()"
              }
            }
          }
        },
        "typing": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid && $roomId.contains(auth.uid)",
            ".validate": "newData.hasChildren(['username','isTyping','updatedAt']) || !newData.exists()",
            "username": { ".validate": "newData.isString() && newData.val().length <= 100" },
            "isTyping": { ".validate": "newData.isBoolean()" },
            "updatedAt": { ".validate": "newData.isNumber()" }
          }
        }
      }
    },

    "forums": {
      "$forumId": {
        ".read": true,

        "threads": {
          "$threadId": {
            ".write": "auth != null && (data.val() === null || data.child('uid').val() === auth.uid)"
          }
        },

        "comments": {
          ".indexOn": ["createdAt"],
          "$commentId": {
            ".write": "auth != null && (data.val() === null || data.child('uid').val() === auth.uid)",
            ".validate": "newData.hasChildren(['uid','text','createdAt']) || !newData.exists()",
            "uid": { ".validate": "newData.val() === auth.uid" },
            "displayName": { ".validate": "newData.isString() && newData.val().length <= 100" },
            "username": { ".validate": "newData.isString() && newData.val().length <= 100" },
            "photoURL": { ".validate": "newData.isString() || newData.val() === null" },
            "text": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 2000" },
            "replyTo": { ".validate": "newData.isString() || newData.val() === null" },
            "createdAt": { ".validate": "newData.isNumber()" },
            "reactions": {
              "$emoji": {
                "$uid": {
                  ".write": "auth != null && auth.uid === $uid",
                  ".validate": "newData.hasChildren(['uid','createdAt']) || !newData.exists()",
                  "uid": { ".validate": "newData.val() === auth.uid" },
                  "createdAt": { ".validate": "newData.isNumber()" }
                }
              }
            }
          }
        },

        "messages": {
          ".indexOn": ["createdAt"],
          "$msgId": {
            ".write": "auth != null && ((data.val() === null && newData.child('uid').val() === auth.uid) || (data.val() !== null && (data.child('uid').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')))",
            ".validate": "newData.hasChildren(['uid','text','createdAt']) || !newData.exists()",
            "uid": { ".validate": "newData.isString()" },
            "displayName": { ".validate": "newData.isString() && newData.val().length <= 100" },
            "username": { ".validate": "newData.isString() && newData.val().length <= 100" },
            "pfp": { ".validate": "newData.isString() && newData.val().length <= 50" },
            "photoURL": { ".validate": "newData.isString() || newData.val() === null" },
            "text": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 2000" },
            "replyTo": { ".validate": "newData.isString() || newData.val() === null" },
            "createdAt": { ".validate": "newData.isNumber()" },
            "updatedAt": { ".validate": "newData.isNumber()" },
            "reactions": {
              "$emoji": {
                "$uid": {
                  ".write": true,
                  ".validate": "newData.hasChildren(['uid','createdAt']) || !newData.exists()",
                  "uid": { ".validate": "newData.isString()" },
                  "createdAt": { ".validate": "newData.isNumber()" }
                }
              }
            }
          }
        },

        "typing": {
          "$uid": {
            ".write": true,
            ".validate": "newData.hasChildren(['username','isTyping','updatedAt']) || !newData.exists()",
            "username": { ".validate": "newData.isString() && newData.val().length <= 100" },
            "isTyping": { ".validate": "newData.isBoolean()" },
            "updatedAt": { ".validate": "newData.isNumber()" }
          }
        },

        "likes": {
          "$uid": {
            ".write": true,
            ".validate": "newData.hasChildren(['uid','createdAt']) || !newData.exists()",
            "uid": { ".validate": "newData.isString()" },
            "createdAt": { ".validate": "newData.isNumber()" }
          }
        }
      }
    }
  }
}
